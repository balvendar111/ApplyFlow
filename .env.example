# LLM: Anthropic first, Ollama fallback when key missing or Anthropic fails
ANTHROPIC_API_KEY=

# Ollama (used when no Anthropic key or on Anthropic failure)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Job APIs (free tiers available)
INDIANAPI_KEY=
RAPIDAPI_KEY=
RAPIDAPI_HOST=jsearch.p.rapidapi.com
# Naukri (RapidAPI - same RAPIDAPI_KEY; set endpoint from API docs)
NAUKRI_RAPIDAPI_HOST=naukri-job-market-intelligence-api.rapidapi.com
# NAUKRI_API_ENDPOINT=search   # optional: /search, /jobs, etc. - check RapidAPI
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# App
DATABASE_URL=sqlite:///./apply_job_bot.db
RESUME_STORAGE_PATH=./resumes

# Auth (production: set strong secret)
JWT_SECRET=change-me-in-production-min-32-chars

# Google OAuth (from Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=

# Password reset (optional - if not set, reset link is logged for dev)
RESET_PASSWORD_BASE_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@applyflow.com

# Production
SERVE_FRONTEND=false
CORS_ORIGINS=http://localhost:5173,https://your-domain.com
